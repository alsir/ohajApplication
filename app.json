{
  "expo": {
    "name": "اوهاج للنقل",
    "slug": "ohajApplication",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#0d1b2a"
    },
    "ios": {
      "supportsTablet": true,
      "infoPlist": {
        "NSLocationWhenInUseUsageDescription": "This app needs your location to send it to the server every minute.",
        "NSLocationAlwaysAndWhenInUseUsageDescription": "This app needs your location in the background to keep sending it every minute.",
        "NSLocationAlwaysUsageDescription": "This app needs your location to send it to the server every minute.",
        "UIBackgroundModes": [
          "location",
          "fetch",
          "location",
          "fetch"
        ],
        "ITSAppUsesNonExemptEncryption": false
      },
      "bundleIdentifier": "com.ohaj.transportation"
    },
    "android": {
      "package": "com.ohaj.transportation",
      "adaptiveIcon": {
        "backgroundColor": "#0d1b2a",
        "foregroundImage": "./assets/android-icon-foreground.png"
      },
      "permissions": [
        "android.permission.ACCESS_FINE_LOCATION",
        "android.permission.ACCESS_COARSE_LOCATION",
        "android.permission.ACCESS_BACKGROUND_LOCATION",
        "android.permission.FOREGROUND_SERVICE",
        "android.permission.FOREGROUND_SERVICE_LOCATION",
        "android.permission.RECEIVE_BOOT_COMPLETED"
      ],
      "predictiveBackGestureEnabled": false
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "extra": {
      "eas": {
        "projectId": "94ab321f-73c1-432a-8d4d-a1194119fa12"
      }
    },
    "owner": "alsiradil",
    "plugins": [
      "expo-secure-store",
      [
        "expo-location",
        {
          "locationAlwaysAndWhenInUsePermission": "This app needs your location to send it to the server every minute.",
          "locationAlwaysPermission": "This app needs your location in the background to keep sending it every minute.",
          "isIosBackgroundLocationEnabled": true,
          "isAndroidBackgroundLocationEnabled": true
        }
      ]
    ]
  }
}
